@model PinePawRetreat.ViewModels.VaccinationVM
@{
    ViewBag.Title = "_VaccCard";
}

<div class="card mb-3">
    <div class="card-body">
        <div class="text-muted mb-1">
            Vaccination Name: @Model.VaccName
        </div>
        <div class="text-muted mb-1">
            Expires: @Model.DateDue
        </div>
        <div class="text-muted mb-1">
            Date Performed: @Model.DatePerformed
        </div>
        <div class="text-muted mb-1">
            Vaccination Verification Status: @Model.VerifiedStatus
        </div>
    </div>
</div>