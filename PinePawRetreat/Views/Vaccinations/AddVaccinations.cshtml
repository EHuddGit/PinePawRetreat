@model PinePawRetreat.ViewModels.VaccinationVM
@{
    ViewBag.Title = "AddVaccinations";
}

@*should add a segment for adding proof of vaccination files*@
@using (Html.BeginForm("AddVaccinations", "Vaccinations", FormMethod.Post))
{
    @Html.ValidationSummary("", new { @class = "text-danger" })
    @Html.HiddenFor(m => m.petID)
    <p>PetID: @Model.petID</p>
    <div class="form-group">
        <div class="form-group">
            <label>Vaccination Name</label>
            @Html.EnumDropDownListFor(m => m.VaccName, "Select an option", new { @class = "form-control" })
        </div>
        <div class="form-group">
            <label>Date Due</label>
            @Html.TextBoxFor(x => x.DateDue, new { @class = "form-control" })
        </div>

        <div class="form-group">
            <label for="exampleInputEmail1">Date Performed</label>
            @Html.TextBoxFor(x => x.DatePerformed, new { @class = "form-control" })
        </div>

        <button type="submit" class="btn btn-primary">Submit</button>
    </div>
}
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
